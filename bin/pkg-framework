#!/usr/bin/env bash
# SPDX-License-Identifier: GPL-3.0-only
#
# pkg-framework -- CLI for managing the vendored framework in a source
# project.
#
# Subcommands:
#   version            print the framework version
#   new <name>         scaffold pkg/ + .github/workflows in a fresh repo
#   sync [--bump]      refresh vendored copies in this repo
#   verify [--quiet]   sha256-check vendored copies against upstream
#
# Discovery: the CLI derives the upstream framework path from its own
# location (../lib relative to this script). Override with
# --framework-path PATH or PKG_FRAMEWORK_HOME env var.
#
# The target source repo is the current working directory by default.
# Override with --target PATH.

set -euo pipefail

# v1.2.2: resolve through symlinks. install.sh symlinks the cli into
# ~/.local/bin/pkg-framework -> ~/.local/share/pkg-framework/bin/pkg-framework.
# Without readlink -f the relative `../` derivation lands at
# ~/.local instead of the framework home, and `version`/`doctor`
# cannot find VERSION. readlink -f follows the chain; if it fails
# (BSD readlink lacks -f), fall back to a python or perl resolver,
# and finally to the unresolved path.
_resolve_real_path() {
    local p=$1
    if command -v readlink >/dev/null 2>&1 && readlink -f -- "$p" >/dev/null 2>&1; then
        readlink -f -- "$p"
    elif command -v python3 >/dev/null 2>&1; then
        python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$p"
    elif command -v perl >/dev/null 2>&1; then
        perl -MCwd=abs_path -E 'say abs_path($ARGV[0])' "$p"
    else
        printf '%s' "$p"
    fi
}
_CLI_REAL_PATH="$(_resolve_real_path "${BASH_SOURCE[0]}")"
CLI_DIR="$(cd -- "$(dirname -- "$_CLI_REAL_PATH")" && pwd)"
DEFAULT_FRAMEWORK_HOME="$(cd -- "$CLI_DIR/.." && pwd)"
FRAMEWORK_HOME="${PKG_FRAMEWORK_HOME:-$DEFAULT_FRAMEWORK_HOME}"
TARGET=""

# Files vendored into source repos. Each entry: "src:dest" with src
# relative to $FRAMEWORK_HOME and dest relative to source repo root.
# Order: directories implied by paths are created on demand.
VENDORED_FILES=(
    "lib/framework.sh:pkg/lib/framework.sh"
    "lib/layout-check.sh:pkg/lib/layout-check.sh"
    "lib/input-tests.sh:pkg/lib/input-tests.sh"
    "VERSION:pkg/lib/VERSION"
    "lib/pkg-build.yml.tmpl:.github/workflows/pkg-build.yml"
)

# Files used only by `new`, not by `sync`.
SCAFFOLD_FILES=(
    "lib/build.sh.example:pkg/build.sh"
    "lib/project.sh.example:pkg/project.sh"
)

# -------------------------------------------------------------------------
# Helpers
# -------------------------------------------------------------------------
die() {
    printf 'pkg-framework: %s\n' "$*" >&2
    exit 1
}

ok() {
    printf '  ok:   %s\n' "$*"
}

warn() {
    printf '  warn: %s\n' "$*"
}

framework_version() {
    if [[ ! -r "$FRAMEWORK_HOME/VERSION" ]]; then
        die "framework VERSION not found at $FRAMEWORK_HOME/VERSION (use --framework-path)"
    fi
    tr -d '\r\n' < "$FRAMEWORK_HOME/VERSION"
}

# Read the FRAMEWORK_VERSION pin from a project.sh. Echoes empty
# string if the pin is missing. Used by sync, verify, status.
_pinned_framework_version() {
    local proj=$1
    [[ -r "$proj" ]] || return 0
    awk -F= '/^FRAMEWORK_VERSION[[:space:]]*=/ {gsub(/[" ]/, "", $2); print $2; exit}' "$proj"
}

# -------------------------------------------------------------------------
# Argument parsing (shared across subcommands)
# -------------------------------------------------------------------------
parse_global_args() {
    REMAINING=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --framework-path)
                shift
                [[ $# -gt 0 ]] || die '--framework-path requires a value'
                FRAMEWORK_HOME="$(cd -- "$1" && pwd)" || die "--framework-path $1 not a directory"
                shift
                ;;
            --target)
                shift
                [[ $# -gt 0 ]] || die '--target requires a value'
                TARGET="$(cd -- "$1" && pwd)" || die "--target $1 not a directory"
                shift
                ;;
            *)
                REMAINING+=("$1")
                shift
                ;;
        esac
    done
}

ensure_target() {
    if [[ -z "$TARGET" ]]; then
        TARGET="$(pwd)"
    fi
    [[ -d "$TARGET" ]] || die "target $TARGET is not a directory"
}

# -------------------------------------------------------------------------
# Subcommand: version
# -------------------------------------------------------------------------
cmd_version() {
    printf '%s\n' "$(framework_version)"
}

# -------------------------------------------------------------------------
# Subcommand: new <name>
# -------------------------------------------------------------------------
cmd_new() {
    local name="${REMAINING[0]:-}"
    [[ -n "$name" ]] || die 'usage: pkg-framework new <project-name>'

    if [[ ! "$name" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
        die "project name '$name' violates debian naming (lowercase alnum + hyphen)"
    fi

    ensure_target

    # No-clobber check across every file we'd write.
    local dest existing=()
    for entry in "${VENDORED_FILES[@]}" "${SCAFFOLD_FILES[@]}"; do
        dest="${entry##*:}"
        if [[ -e "$TARGET/$dest" ]]; then
            existing+=("$dest")
        fi
    done
    if [[ "${#existing[@]}" -gt 0 ]]; then
        printf 'pkg-framework: refuses to overwrite existing files in %s:\n' "$TARGET" >&2
        printf '  - %s\n' "${existing[@]}" >&2
        printf '\nUse `pkg-framework sync` to refresh vendored files in an existing repo.\n' >&2
        exit 1
    fi

    local fv
    fv="$(framework_version)"

    # Stage the scaffolded files with substitutions.
    local upper
    upper="$(printf '%s' "$name" | tr '[:lower:]-' '[:upper:]_')"

    printf 'scaffolding pkg-framework project "%s" (framework %s) into %s\n' \
        "$name" "$fv" "$TARGET"

    for entry in "${VENDORED_FILES[@]}" "${SCAFFOLD_FILES[@]}"; do
        local src="${entry%%:*}"
        dest="${entry##*:}"
        local src_full="$FRAMEWORK_HOME/$src"
        local dest_full="$TARGET/$dest"
        install -D -m 0644 "$src_full" "$dest_full"
        ok "wrote $dest"
    done

    # Make the entry points executable.
    chmod 0755 "$TARGET/pkg/build.sh"

    # Substitute placeholders in the scaffolded project.sh.
    local proj="$TARGET/pkg/project.sh"
    sed -i.bak \
        -e "s/^PKG_NAME=myproject/PKG_NAME=$name/" \
        -e "s/^PKG_PREFIX=MYPROJECT/PKG_PREFIX=$upper/" \
        -e "s/^FRAMEWORK_VERSION=.*/FRAMEWORK_VERSION=$fv/" \
        "$proj"
    rm -f "${proj}.bak"
    ok "substituted PKG_NAME=$name PKG_PREFIX=$upper FRAMEWORK_VERSION=$fv in pkg/project.sh"

    cat <<EOF

Next steps:
  1. Edit pkg/project.sh and replace the example fields (summary,
     description, vendor, maintainer, URLs, license, binaries, deps).
  2. Implement project_stage_extra / project_postinst_body hooks if
     your project ships configs, polkit, sudoers, etc.
  3. Commit and push. The pkg-build workflow runs on every PR.
EOF
}

# -------------------------------------------------------------------------
# Subcommand: sync
# -------------------------------------------------------------------------
cmd_sync() {
    ensure_target

    local bump=0
    local arg
    for arg in "${REMAINING[@]}"; do
        case "$arg" in
            --bump) bump=1 ;;
            *) die "unknown sync flag: $arg" ;;
        esac
    done

    local fv
    fv="$(framework_version)"

    local proj="$TARGET/pkg/project.sh"
    if [[ ! -r "$proj" ]]; then
        die "$proj not found -- is this a pkg-framework source repo? (use \`new\` to scaffold)"
    fi

    # Detect pinned version in project.sh.
    local pinned
    pinned=$(_pinned_framework_version "$proj")

    if [[ -z "$pinned" ]]; then
        warn "no FRAMEWORK_VERSION pin in pkg/project.sh -- adding $fv"
    elif [[ "$pinned" != "$fv" ]]; then
        if [[ "$bump" -ne 1 ]]; then
            printf 'pkg-framework: pinned FRAMEWORK_VERSION=%s but upstream is %s\n' \
                "$pinned" "$fv" >&2
            printf 'Use `pkg-framework sync --bump` to acknowledge the version change.\n' >&2
            exit 1
        fi
        warn "bumping FRAMEWORK_VERSION pin from $pinned to $fv"
    else
        ok "FRAMEWORK_VERSION pin already at $fv"
    fi

    # Copy each vendored file (overwrite).
    local entry src dest
    for entry in "${VENDORED_FILES[@]}"; do
        src="${entry%%:*}"
        dest="${entry##*:}"
        install -D -m 0644 "$FRAMEWORK_HOME/$src" "$TARGET/$dest"
        ok "synced $dest"
    done

    # Update the FRAMEWORK_VERSION pin in pkg/project.sh.
    if grep -qE '^FRAMEWORK_VERSION[[:space:]]*=' "$proj"; then
        sed -i.bak -E "s/^FRAMEWORK_VERSION[[:space:]]*=.*/FRAMEWORK_VERSION=$fv/" "$proj"
        rm -f "${proj}.bak"
    else
        # Append the pin.
        printf '\nFRAMEWORK_VERSION=%s\n' "$fv" >> "$proj"
    fi
    ok "FRAMEWORK_VERSION=$fv pinned in pkg/project.sh"

    printf '\nsync complete (framework %s)\n' "$fv"
    printf 'Recommended: run `pkg-framework verify` to confirm the working tree matches.\n'
}

# -------------------------------------------------------------------------
# Subcommand: verify
# -------------------------------------------------------------------------
cmd_verify() {
    ensure_target

    local quiet=0
    local arg
    for arg in "${REMAINING[@]}"; do
        case "$arg" in
            --quiet) quiet=1 ;;
            *) die "unknown verify flag: $arg" ;;
        esac
    done

    local entry src dest src_sha dest_sha mismatches=0
    for entry in "${VENDORED_FILES[@]}"; do
        src="${entry%%:*}"
        dest="${entry##*:}"
        local src_full="$FRAMEWORK_HOME/$src"
        local dest_full="$TARGET/$dest"
        if [[ ! -r "$src_full" ]]; then
            die "upstream missing: $src_full"
        fi
        if [[ ! -r "$dest_full" ]]; then
            printf 'pkg-framework: MISSING %s (run `pkg-framework sync`)\n' "$dest" >&2
            mismatches=$(( mismatches + 1 ))
            continue
        fi
        src_sha=$(sha256sum "$src_full" | awk '{print $1}')
        dest_sha=$(sha256sum "$dest_full" | awk '{print $1}')
        if [[ "$src_sha" != "$dest_sha" ]]; then
            printf 'pkg-framework: DRIFT  %s\n' "$dest" >&2
            printf '  upstream sha256: %s\n' "$src_sha" >&2
            printf '  vendored sha256: %s\n' "$dest_sha" >&2
            mismatches=$(( mismatches + 1 ))
        elif [[ "$quiet" -ne 1 ]]; then
            ok "$dest"
        fi
    done

    # Also check the FRAMEWORK_VERSION pin matches.
    local proj="$TARGET/pkg/project.sh"
    if [[ -r "$proj" ]]; then
        local pinned fv
        pinned=$(_pinned_framework_version "$proj")
        fv="$(framework_version)"
        if [[ -z "$pinned" ]]; then
            printf 'pkg-framework: pkg/project.sh has no FRAMEWORK_VERSION pin\n' >&2
            mismatches=$(( mismatches + 1 ))
        elif [[ "$pinned" != "$fv" ]]; then
            printf 'pkg-framework: FRAMEWORK_VERSION pin %s != upstream %s\n' \
                "$pinned" "$fv" >&2
            mismatches=$(( mismatches + 1 ))
        elif [[ "$quiet" -ne 1 ]]; then
            ok "FRAMEWORK_VERSION pin matches ($fv)"
        fi
    fi

    if [[ "$mismatches" -gt 0 ]]; then
        printf '\n%d drift(s) detected\n' "$mismatches" >&2
        exit 1
    fi
    [[ "$quiet" -eq 1 ]] || printf '\nverified clean (framework %s)\n' "$(framework_version)"
}

# -------------------------------------------------------------------------
# Subcommand: init (interactive wizard around `new`)
#
# Reads Cargo.toml, git remote, LICENSE, and git config to pre-fill the
# manifest. Prompts only for fields it cannot detect. Then runs the
# same scaffold as `new` and patches the resolved values into
# pkg/project.sh.
#
# Non-interactive mode (--yes) accepts every detected default and
# leaves anything undetected at the example value. Useful in CI to
# scaffold a deterministic project for tests.
# -------------------------------------------------------------------------
cmd_init() {
    ensure_target

    local yes=0
    local name=""
    local arg
    for arg in "${REMAINING[@]+"${REMAINING[@]}"}"; do
        case "$arg" in
            --yes|-y) yes=1 ;;
            -h|--help)
                cat <<H
Usage: pkg-framework init [<name>] [--yes]

Interactive scaffold. Reads Cargo.toml, git remote, LICENSE, and git
config to autofill the manifest; prompts only for what cannot be
detected. With --yes accepts every detected default without
prompting (useful in CI).
H
                return 0
                ;;
            -*) die "init: unknown flag $arg" ;;
            *)  [[ -z "$name" ]] && name=$arg || die "init: unexpected arg $arg" ;;
        esac
    done

    # ---- detect ---------------------------------------------------------
    local det_name="" det_summary="" det_homepage="" det_source=""
    local det_license="" det_maintainer="" det_bin=""

    if [[ -r "$TARGET/Cargo.toml" ]]; then
        det_name=$(awk -F'"' '/^[[:space:]]*name[[:space:]]*=/ {print $2; exit}' "$TARGET/Cargo.toml")
        det_summary=$(awk -F'"' '/^[[:space:]]*description[[:space:]]*=/ {print $2; exit}' "$TARGET/Cargo.toml")
        det_license=$(awk -F'"' '/^[[:space:]]*license[[:space:]]*=/ {print $2; exit}' "$TARGET/Cargo.toml")
        det_bin="$det_name"
    fi

    if git -C "$TARGET" rev-parse --git-dir >/dev/null 2>&1; then
        local origin
        origin=$(git -C "$TARGET" remote get-url origin 2>/dev/null || true)
        if [[ -n "$origin" ]]; then
            # Normalize git@github.com:owner/repo[.git] -> https://github.com/owner/repo
            origin=${origin%.git}
            case "$origin" in
                git@*:*) origin="https://${origin#git@}"; origin=${origin/:/\/} ;;
            esac
            det_homepage=$origin
            det_source=$origin
        fi
        local gname gemail
        gname=$(git -C "$TARGET" config user.name 2>/dev/null || true)
        gemail=$(git -C "$TARGET" config user.email 2>/dev/null || true)
        [[ -n "$gname" && -n "$gemail" ]] && det_maintainer="$gname <$gemail>"
    fi

    # LICENSE first non-blank line (SPDX-License-Identifier preferred).
    if [[ -z "$det_license" && -r "$TARGET/LICENSE" ]]; then
        det_license=$(grep -oE 'SPDX-License-Identifier:[[:space:]]*[A-Za-z0-9.+-]+' \
            "$TARGET/LICENSE" | head -1 | awk '{print $NF}')
    fi

    # Fall back to the supplied name argument.
    [[ -z "$det_name" && -n "$name" ]] && det_name=$name

    # ---- prompt ---------------------------------------------------------
    local p_name p_summary p_homepage p_source p_license p_maintainer p_vendor
    _ask() {
        local label=$1 default=$2
        if [[ "$yes" == "1" ]]; then
            printf '%s\n' "$default"
            return
        fi
        local reply
        printf '  %s [%s]: ' "$label" "$default" >&2
        IFS= read -r reply </dev/tty || reply=""
        printf '%s\n' "${reply:-$default}"
    }

    [[ "$yes" == "1" ]] || printf 'pkg-framework init: detected values shown in brackets; press enter to accept.\n\n'
    p_name=$(_ask       "PKG_NAME (debian-naming)"      "${det_name:-myproject}")
    p_summary=$(_ask    "PKG_SUMMARY (one line)"        "${det_summary:-One-line description}")
    p_homepage=$(_ask   "PKG_HOMEPAGE_URL"              "${det_homepage:-https://example.com/$p_name}")
    p_source=$(_ask     "PKG_SOURCE_URL"                "${det_source:-$p_homepage}")
    p_license=$(_ask    "PKG_LICENSE_SPDX"              "${det_license:-GPL-3.0-only}")
    p_maintainer=$(_ask "PKG_MAINTAINER (Name <email>)" "${det_maintainer:-You <you@example.com>}")
    p_vendor=$(_ask     "PKG_VENDOR"                    "Lou's Clues Labs")

    # ---- scaffold via cmd_new ------------------------------------------
    REMAINING=("$p_name")
    cmd_new

    # ---- patch project.sh with the prompted values ---------------------
    local proj="$TARGET/pkg/project.sh"
    [[ -r "$proj" ]] || die "init: scaffold did not produce $proj"

    # Escape forward slashes for sed.
    local _e
    _e() { printf '%s' "$1" | sed -e 's/[\/&]/\\&/g'; }

    sed -i.bak \
        -e "s/^PKG_SUMMARY=.*/PKG_SUMMARY=\"$(_e "$p_summary")\"/" \
        -e "s|^PKG_HOMEPAGE_URL=.*|PKG_HOMEPAGE_URL=\"$p_homepage\"|" \
        -e "s|^PKG_SOURCE_URL=.*|PKG_SOURCE_URL=\"$p_source\"|" \
        -e "s/^PKG_LICENSE_SPDX=.*/PKG_LICENSE_SPDX=\"$(_e "$p_license")\"/" \
        -e "s/^PKG_LICENSE_NAME=.*/PKG_LICENSE_NAME=\"$(_e "$p_license")\"/" \
        -e "s/^PKG_MAINTAINER=.*/PKG_MAINTAINER=\"$(_e "$p_maintainer")\"/" \
        -e "s/^PKG_VENDOR=.*/PKG_VENDOR=\"$(_e "$p_vendor")\"/" \
        "$proj"
    rm -f "${proj}.bak"

    # Best-effort PKG_BINARIES: if we detected a cargo bin name, swap it.
    if [[ -n "$det_bin" ]]; then
        sed -i.bak -E "s/^PKG_BINARIES=\\($det_name.*/PKG_BINARIES=($det_bin)/" "$proj"
        sed -i.bak -E "s/^PKG_BINARIES=\\(myproject\\)/PKG_BINARIES=($det_bin)/" "$proj"
        rm -f "${proj}.bak"
    fi

    printf '\ninit: pkg/project.sh populated. Review with:\n  $EDITOR %s\n' "$proj"
    printf 'Then run:\n  pkg-framework lint\n  pkg-framework dry-run\n'
}

# -------------------------------------------------------------------------
# Subcommand: doctor
# -------------------------------------------------------------------------
cmd_doctor() {
    local rc=0
    local b
    printf 'pkg-framework doctor\n'
    printf '  framework: %s\n' "$(framework_version)"
    printf '  home:      %s\n' "$FRAMEWORK_HOME"
    printf '\n'

    # Required tools. Without these the framework cannot run.
    local required=(bash sha256sum awk sed install grep find tr)
    for b in "${required[@]}"; do
        if command -v "$b" >/dev/null 2>&1; then
            ok "$b ($(command -v "$b"))"
        else
            printf '  FAIL: %s not on PATH (required)\n' "$b" >&2
            rc=1
        fi
    done

    # Bash version. We need 4+ for mapfile / associative arrays.
    local bash_major
    bash_major=${BASH_VERSION%%.*}
    if [[ "$bash_major" -ge 4 ]]; then
        ok "bash $BASH_VERSION (>= 4)"
    else
        printf '  FAIL: bash %s; need 4 or newer\n' "$BASH_VERSION" >&2
        rc=1
    fi

    printf '\n  optional (only needed at build time):\n'
    local optional=(cargo fpm docker podman dnf apt-get)
    for b in "${optional[@]}"; do
        if command -v "$b" >/dev/null 2>&1; then
            ok "$b ($(command -v "$b"))"
        else
            warn "$b not on PATH"
        fi
    done

    printf '\n'
    if [[ "$rc" -eq 0 ]]; then
        printf 'doctor: ready\n'
    else
        printf 'doctor: missing required tools (install above and re-run)\n' >&2
    fi
    return "$rc"
}

# -------------------------------------------------------------------------
# Subcommand: lint
#
# Validates pkg/project.sh against the manifest schema. No build, no
# fpm, no network. Sub-second feedback during onboarding.
# -------------------------------------------------------------------------
cmd_lint() {
    ensure_target
    local proj="$TARGET/pkg/project.sh"
    if [[ ! -r "$proj" ]]; then
        die "$proj not found (run \`pkg-framework new <name>\` first)"
    fi

    # Source the manifest in a subshell so we do not pollute our env.
    # `set -u` would trip on optional fields; we use `set +u` inside.
    local lint_rc=0
    local lint_out
    lint_out=$(
        set +u
        # shellcheck disable=SC1090
        source "$proj"
        rc=0
        _miss() { printf '  FAIL: %s is required but unset or empty\n' "$1"; rc=1; }
        # Required scalars.
        [[ -n "${PKG_NAME:-}" ]]              || _miss PKG_NAME
        [[ -n "${PKG_PREFIX:-}" ]]            || _miss PKG_PREFIX
        [[ -n "${PKG_SUMMARY:-}" ]]           || _miss PKG_SUMMARY
        [[ -n "${PKG_DESCRIPTION:-}" ]]       || _miss PKG_DESCRIPTION
        [[ -n "${PKG_VENDOR:-}" ]]            || _miss PKG_VENDOR
        [[ -n "${PKG_MAINTAINER:-}" ]]        || _miss PKG_MAINTAINER
        [[ -n "${PKG_HOMEPAGE_URL:-}" ]]      || _miss PKG_HOMEPAGE_URL
        [[ -n "${PKG_SOURCE_URL:-}" ]]        || _miss PKG_SOURCE_URL
        [[ -n "${PKG_LICENSE_SPDX:-}" ]]      || _miss PKG_LICENSE_SPDX
        [[ -n "${PKG_LICENSE_NAME:-}" ]]      || _miss PKG_LICENSE_NAME
        [[ -n "${PKG_COPYRIGHT_HOLDERS:-}" ]] || _miss PKG_COPYRIGHT_HOLDERS
        [[ -n "${PKG_COPYRIGHT_YEAR:-}" ]]    || _miss PKG_COPYRIGHT_YEAR
        [[ -n "${FRAMEWORK_VERSION:-}" ]]     || _miss FRAMEWORK_VERSION

        # Required arrays. Bash test: declare -p exits 0 if defined.
        if ! declare -p PKG_BINARIES >/dev/null 2>&1; then
            printf '  FAIL: PKG_BINARIES must be an array\n'; rc=1
        elif [[ "${#PKG_BINARIES[@]}" -eq 0 ]]; then
            printf '  FAIL: PKG_BINARIES is empty\n'; rc=1
        fi
        if ! declare -p PKG_DEB_DEPENDS >/dev/null 2>&1; then
            printf '  FAIL: PKG_DEB_DEPENDS must be an array (may be empty)\n'; rc=1
        fi
        if ! declare -p PKG_LAYOUT_CHECKS >/dev/null 2>&1; then
            printf '  FAIL: PKG_LAYOUT_CHECKS must be an array\n'; rc=1
        else
            # Each entry is path:mode. Mode must be 3 or 4 octal digits.
            local e
            for e in "${PKG_LAYOUT_CHECKS[@]}"; do
                if [[ ! "$e" =~ ^[^:]+:[0-7]{3,4}$ ]]; then
                    printf '  FAIL: PKG_LAYOUT_CHECKS entry malformed: %s (expect path:NNN)\n' "$e"
                    rc=1
                fi
            done
        fi

        # PKG_NAME must be debian-naming compliant.
        if [[ -n "${PKG_NAME:-}" && ! "$PKG_NAME" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
            printf '  FAIL: PKG_NAME=%s violates debian naming (lowercase alnum + hyphen)\n' "$PKG_NAME"
            rc=1
        fi
        # PKG_PREFIX must be uppercase + underscore.
        if [[ -n "${PKG_PREFIX:-}" && ! "$PKG_PREFIX" =~ ^[A-Z][A-Z0-9_]*$ ]]; then
            printf '  FAIL: PKG_PREFIX=%s must be uppercase + underscore\n' "$PKG_PREFIX"
            rc=1
        fi

        exit "$rc"
    )
    lint_rc=$?
    [[ -n "$lint_out" ]] && printf '%s\n' "$lint_out"
    if [[ "$lint_rc" -eq 0 ]]; then
        ok "manifest schema valid ($proj)"
    fi
    return "$lint_rc"
}

# -------------------------------------------------------------------------
# Subcommand: dry-run
#
# Print what the framework would do, without invoking fpm. The output
# is meant to be reviewer-friendly: a packaging change shows up as a
# diff in the dry-run output across commits.
# -------------------------------------------------------------------------
cmd_dry_run() {
    ensure_target
    local proj="$TARGET/pkg/project.sh"
    [[ -r "$proj" ]] || die "$proj not found (run \`pkg-framework new <name>\` first)"

    (
        set +u
        # shellcheck disable=SC1090
        source "$proj"
        local fv
        fv=$(framework_version)
        printf 'pkg-framework dry-run\n'
        printf '  framework:  %s\n' "$fv"
        printf '  project:    %s\n' "${PKG_NAME:-?}"
        printf '  prefix:     %s\n' "${PKG_PREFIX:-?}"
        printf '  vendor:     %s\n' "${PKG_VENDOR:-?}"
        printf '  maintainer: %s\n' "${PKG_MAINTAINER:-?}"
        printf '  license:    %s\n' "${PKG_LICENSE_SPDX:-?}"
        printf '\n'
        printf '  binaries:\n'
        local b
        for b in "${PKG_BINARIES[@]:-}"; do
            printf '    cargo build --release --bin %s\n' "$b"
        done
        printf '\n'
        printf '  staging tree (PKG_LAYOUT_CHECKS):\n'
        local e
        for e in "${PKG_LAYOUT_CHECKS[@]:-}"; do
            printf '    %s\n' "$e"
        done
        printf '\n'
        printf '  deb depends:\n'
        for e in "${PKG_DEB_DEPENDS[@]:-}"; do
            printf '    Depends: %s\n' "$e"
        done
        printf '\n'
        printf '  fpm invocations (resolved):\n'
        printf '    fpm -s dir -t deb -n %s -v <VERSION> --license %q ...\n' \
            "${PKG_NAME:-?}" "${PKG_LICENSE_SPDX:-?}"
        printf '    fpm -s dir -t rpm -n %s -v <VERSION> --license %q ...\n' \
            "${PKG_NAME:-?}" "${PKG_LICENSE_SPDX:-?}"
        printf '\n'
        printf '  hooks defined:\n'
        local h
        for h in project_stage_extra project_pre_build project_post_build \
                 project_postinst_body project_prerm_body project_postrm_body \
                 project_fpm_deb_extra_args project_fpm_rpm_extra_args \
                 project_validate_stage_extra project_install_layout_check_extra; do
            if declare -F "$h" >/dev/null 2>&1; then
                printf '    %s (defined)\n' "$h"
            fi
        done
        printf '\n'
        printf 'dry-run: no commands executed; pass --target/--framework-path to retarget\n'
    )
}

# -------------------------------------------------------------------------
# Subcommand: status
#
# One-liner summary suitable for CI status checks and READMEs.
# -------------------------------------------------------------------------
cmd_status() {
    ensure_target
    local json=0
    local arg
    for arg in "${REMAINING[@]+"${REMAINING[@]}"}"; do
        case "$arg" in
            --json) json=1 ;;
            -h|--help)
                cat <<H
Usage: pkg-framework status [--json]

One-line summary of the vendored copy versus upstream:
  framework=<v>  the upstream pkg-framework version
  pinned=<v>     the FRAMEWORK_VERSION pinned in pkg/project.sh
  drift=<n>      count of vendored files that differ from upstream

Exit 0 only when drift == 0 AND pinned == framework. With --json
emits a parseable envelope on stdout instead of the human one-liner.
H
                return 0
                ;;
            *) die "status: unknown flag $arg" ;;
        esac
    done

    local proj="$TARGET/pkg/project.sh"
    local fv pinned drift=0
    fv=$(framework_version)
    pinned=$(_pinned_framework_version "$proj")
    [[ -z "$pinned" ]] && pinned="<unpinned>"

    local entry src dest src_sha dest_sha drifted_files=()
    for entry in "${VENDORED_FILES[@]}"; do
        src="${entry%%:*}"
        dest="${entry##*:}"
        if [[ ! -r "$TARGET/$dest" ]]; then
            drift=$(( drift + 1 ))
            drifted_files+=("$dest")
            continue
        fi
        src_sha=$(sha256sum "$FRAMEWORK_HOME/$src" | awk '{print $1}')
        dest_sha=$(sha256sum "$TARGET/$dest" | awk '{print $1}')
        if [[ "$src_sha" != "$dest_sha" ]]; then
            drift=$(( drift + 1 ))
            drifted_files+=("$dest")
        fi
    done

    if [[ "$json" == "1" ]]; then
        local files_json="[]"
        if [[ "${#drifted_files[@]}" -gt 0 ]]; then
            local f joined
            for f in "${drifted_files[@]}"; do
                joined+="\"$f\","
            done
            files_json="[${joined%,}]"
        fi
        printf '{"schema":"pkg-framework-status/1","framework":"%s","pinned":"%s","drift":%d,"drifted_files":%s}\n' \
            "$fv" "$pinned" "$drift" "$files_json"
    else
        printf 'framework=%s pinned=%s drift=%d\n' "$fv" "$pinned" "$drift"
    fi
    [[ "$drift" -eq 0 && "$pinned" == "$fv" ]]
}

# -------------------------------------------------------------------------
# Subcommand: upgrade (alias for `sync --bump`)
# -------------------------------------------------------------------------
cmd_upgrade() {
    REMAINING=("--bump" "${REMAINING[@]}")
    cmd_sync
}

# -------------------------------------------------------------------------
# Subcommand: completion bash
# -------------------------------------------------------------------------
cmd_completion() {
    local shell="${REMAINING[0]:-}"
    case "$shell" in
        bash) ;;
        ""|-h|--help)
            cat <<'H'
Usage: pkg-framework completion bash

Emit a bash-completion script on stdout. Source it (or drop into
/etc/bash_completion.d/) for tab completion over subcommands and
flags.
H
            return 0 ;;
        *) die "completion: unknown shell '$shell' (only bash is supported)" ;;
    esac

    cat <<'COMPLETION'
# pkg-framework bash completion. Source from ~/.bashrc:
#   . <(pkg-framework completion bash)
_pkg_framework_complete() {
    local cur prev cmds
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"
    cmds="version new init sync verify upgrade status doctor lint dry-run completion help"

    if [[ "$COMP_CWORD" -eq 1 ]]; then
        # shellcheck disable=SC2207
        COMPREPLY=( $(compgen -W "$cmds" -- "$cur") )
        return 0
    fi

    case "${COMP_WORDS[1]}" in
        sync)
            # shellcheck disable=SC2207
            COMPREPLY=( $(compgen -W "--bump --framework-path --target" -- "$cur") ) ;;
        verify)
            # shellcheck disable=SC2207
            COMPREPLY=( $(compgen -W "--quiet --framework-path --target" -- "$cur") ) ;;
        new|status|lint|dry-run|upgrade|init)
            # shellcheck disable=SC2207
            COMPREPLY=( $(compgen -W "--framework-path --target --yes" -- "$cur") ) ;;
        completion)
            # shellcheck disable=SC2207
            COMPREPLY=( $(compgen -W "bash" -- "$cur") ) ;;
    esac
}
complete -F _pkg_framework_complete pkg-framework
COMPLETION
}

# -------------------------------------------------------------------------
# Dispatch
# -------------------------------------------------------------------------
usage() {
    cat <<'EOF'
usage: pkg-framework <subcommand> [args]

subcommands:
  version                  print framework version
  doctor                   environment preflight (required + optional tools)
  new <name>               scaffold pkg/ + .github/workflows in cwd
  init [<name>] [--yes]    interactive scaffold (autofills from
                           Cargo.toml, git remote, LICENSE, git config)
  sync [--bump]            refresh vendored files in this source repo
  upgrade                  alias for `sync --bump`
  verify [--quiet]         sha256-check vendored files against upstream
  status [--json]          one-liner: framework=X pinned=Y drift=N
  lint                     validate pkg/project.sh against the schema
  dry-run                  print the fpm commands without executing them
  completion bash          emit a bash completion script

options (any subcommand):
  --framework-path PATH    upstream framework dir (default: derived from
                           cli location; env: PKG_FRAMEWORK_HOME)
  --target PATH            source repo to operate on (default: cwd)

EOF
}

main() {
    if [[ $# -eq 0 ]]; then
        usage
        exit 64
    fi

    # Pre-pass: peel off any global flags (--framework-path, --target)
    # that the operator put BEFORE the subcommand. Anything else stays
    # in $@ for the subcommand pickup below. Lets `pkg-framework
    # --target X new foo` work as well as `pkg-framework new --target
    # X foo`.
    local _pre=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --framework-path|--target)
                _pre+=("$1" "${2:-}")
                shift 2
                ;;
            --framework-path=*|--target=*)
                _pre+=("$1")
                shift
                ;;
            *)
                break
                ;;
        esac
    done

    if [[ $# -eq 0 ]]; then
        usage
        exit 64
    fi
    local sub="$1"
    shift
    case "$sub" in
        -h|--help|help) usage; exit 0 ;;
    esac

    parse_global_args "${_pre[@]+"${_pre[@]}"}" "$@"

    case "$sub" in
        version)    cmd_version ;;
        new)        cmd_new ;;
        init)       cmd_init ;;
        sync)       cmd_sync ;;
        upgrade)    cmd_upgrade ;;
        verify)     cmd_verify ;;
        status)     cmd_status ;;
        doctor)     cmd_doctor ;;
        lint)       cmd_lint ;;
        dry-run)    cmd_dry_run ;;
        completion) cmd_completion ;;
        *)
            printf 'pkg-framework: unknown subcommand: %s\n' "$sub" >&2
            usage >&2
            exit 64
            ;;
    esac
}

main "$@"
